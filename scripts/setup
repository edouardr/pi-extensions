#!/bin/bash
set -e

sudo mkdir -p /home/vscode/.local/share /home/vscode/.local/state /home/vscode/.cache
sudo chown -R vscode:vscode /home/vscode/.local /home/vscode/.cache

# Import GPG public key if available (mounted from host)
if [ -f /tmp/pubkey.asc ]; then
  gpg --import /tmp/pubkey.asc
  gpg --import-ownertrust /tmp/ownertrust.asc 2>/dev/null || true
  find /home/vscode/.gnupg/private-keys-v1.d/ -name "*.key" -delete 2>/dev/null || true

  # Create gpg config
  echo "pinentry-mode loopback" >/home/vscode/.gnupg/gpg.conf
  echo "use-agent" >>/home/vscode/.gnupg/gpg.conf

  # Create agent config
  echo "allow-loopback-pinentry" >/home/vscode/.gnupg/gpg-agent.conf

  gpg-connect-agent reloadagent /bye
fi

/usr/local/bin/mise trust /workspaces/"$DEVPOD_WORKSPACE_ID"/mise.toml && /usr/local/bin/mise install
